# Copy to `.env` locally; set in Vercel project settings for deploy.
# Never commit real keys.

# Public Supabase project URL (Settings → API).
NUXT_PUBLIC_SUPABASE_URL=

# Server-only — service role (Settings → API). Used only by Nitro; never in client bundle.
NUXT_SUPABASE_SERVICE_ROLE_KEY=

# Server-only — Google AI (Gemini) for hybrid intake classification on POST /api/intake/analyze. Optional; keyword parser runs if unset or on failure.
NUXT_GEMINI_API_KEY=
